---
layout: base.njk
---
<a href=".." class="back-link">← Back to Camp Overview</a>

<h1>{{ title }}</h1>

<section>
  <!-- Optional summary of the day -->
  {{ content | safe }}
</section>

<section>
  <h2>Today's Topics</h2>
  <ol class="module-list">
    <!-- Loops through the specific notes for this day -->
    {% set notes = collections[noteTag] | sort(false, false, 'data.order') %}
    {% for note in notes %}
      <li>
        <a href="{{ note.url }}" class="module-link">{{ note.data.title }}</a>
      </li>
    {% endfor %}
  </ol>
</section>
