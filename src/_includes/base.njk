<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="icon" href="/logos/wattson.svg" sizes="any" type="image/svg+xml">
	  <link
			href="https://unpkg.com/prismjs@1.20.0/themes/prism-okaidia.css"
			rel="stylesheet"
		/>
</head>
<body>
    <header>
      <nav>
        <!-- We add a container to align the nav with the main content -->
        <div class="nav-container">
          <a href="/" class="nav-brand">
            <img class="nav-icon" src="/logos/logo.svg" alt="Science Alive Logo">
          </a>
        </div>
      </nav>
    </header>

    <!-- The content from the other layouts is injected here -->
    <main class="container">
      {{ content | safe }}
    </main>
</body>
</html>
